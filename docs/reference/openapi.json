        "properties": {
          "ref": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ref"
          },
          "repo_url": {
            "format": "uri",
            "maxLength": 2083,
            "minLength": 1,
            "title": "Repo Url",
            "type": "string"
          }
        },
        "required": [
          "repo_url"
        ],
        "title": "CreateScanRequest",
        "type": "object"
      },
      "CreateScanResponse": {
        "properties": {
          "job_id": {
            "title": "Job Id",
            "type": "string"
          },
          "scan_id": {
            "title": "Scan Id",
            "type": "integer"
          },
          "status": {
            "const": "queued",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "scan_id",
          "status",
          "job_id"
        ],
        "title": "CreateScanResponse",
        "type": "object"
      },
      "FindingItemResponse": {
        "properties": {
          "confidence": {
            "title": "Confidence",
