            "title": "Finished At"
          },
          "high_count": {
            "title": "High Count",
            "type": "integer"
          },
          "low_count": {
            "title": "Low Count",
            "type": "integer"
          },
          "medium_count": {
            "title": "Medium Count",
            "type": "integer"
          },
          "repo_url": {
            "title": "Repo Url",
            "type": "string"
