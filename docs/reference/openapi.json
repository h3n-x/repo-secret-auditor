            "type": "integer"
          },
          "line_end": {
            "title": "Line End",
            "type": "integer"
          },
          "line_start": {
            "title": "Line Start",
            "type": "integer"
          },
          "recommendation": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Recommendation"
          },
          "rule_id": {
            "title": "Rule Id",
            "type": "string"
          },
          "severity": {
            "title": "Severity",
            "type": "string"
          },
          "type": {
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "id",
          "type",
          "rule_id",
          "file_path",
          "line_start",
          "line_end",
          "severity",
          "confidence",
          "recommendation"
        ],
        "title": "FindingItemResponse",
        "type": "object"
      },
      "FindingListResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/FindingItemResponse"
            },
            "title": "Items",
            "type": "array"
          },
          "limit": {
            "title": "Limit",
            "type": "integer"
          },
          "offset": {
            "title": "Offset",
            "type": "integer"
          },
          "scan_id": {
            "title": "Scan Id",
            "type": "integer"
          },
          "total": {
            "title": "Total",
            "type": "integer"
          },
          "version": {
            "const": "v1",
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "version",
          "scan_id",
          "total",
          "limit",
          "offset",
          "items"
        ],
        "title": "FindingListResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ScanDetailResponse": {
        "properties": {
          "commit_sha": {
            "anyOf": [
              {
