  "info": {
    "title": "Repo Secret & Dependency Auditor API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/scans": {
      "post": {
        "description": "Create a new security scan for a repository.\n\n**Security Notes:**\n- Rate limited to 10 requests per minute per IP.\n- Git URL validated against whitelist (github.com, gitlab.com, etc.).\n- Git ref validated to prevent malicious input.\n- All logging is sanitized to hide secrets.",
        "operationId": "create_scan_scans_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateScanRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateScanResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Create Scan",
        "tags": [
          "scans"
        ]
      }
    },
    "/scans/{scan_id}": {
      "get": {
        "description": "Get details of a scan.",
        "operationId": "get_scan_scans__scan_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "scan_id",
            "required": true,
            "schema": {
              "title": "Scan Id",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScanDetailResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Scan",
        "tags": [
          "scans"
        ]
      }
    },
    "/scans/{scan_id}/findings": {
      "get": {
        "description": "Get findings for a scan with optional filtering.\n\n**Security Notes:**\n- Rate limited to 30 requests per minute per IP.\n- Severity and type filters validated against allowed values.\n- Pagination enforced to prevent large result exfiltration.",
        "operationId": "get_scan_findings_scans__scan_id__findings_get",
        "parameters": [
          {
            "in": "path",
            "name": "scan_id",
            "required": true,
            "schema": {
              "title": "Scan Id",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "severity",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Severity"
            }
          },
          {
            "in": "query",
            "name": "type",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Type"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 50,
              "maximum": 200,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "offset",
            "required": false,
            "schema": {
              "default": 0,
              "minimum": 0,
              "title": "Offset",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FindingListResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Scan Findings",
        "tags": [
          "scans"
        ]
      }
    }
  }
}